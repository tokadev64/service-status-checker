{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno task dev:api & deno task dev:web",
    "dev:api": "deno run -A --watch server/main.ts",
    "dev:web": "deno run -A npm:vite@7.1.5",
    "build": "deno run -A npm:vite@7.1.5 build",
    "preview": "deno task build && deno run -A server/main.ts",
    "lint": "deno run -A npm:@biomejs/biome@2.3.8 check .",
    "fmt": "deno fmt && deno run -A npm:@biomejs/biome@2.3.8 format --write .",
    "test": "deno test",
    "check": "deno task lint && deno task test"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.15",
    "@std/datetime": "jsr:@std/datetime@^0.225.3",
    "@std/http": "jsr:@std/http@^1.0.21",
    "fast-check": "npm:fast-check@^4.3.0",
    "hono": "jsr:@hono/hono@^4.9.6",
    "hono/cors": "jsr:@hono/hono@^4.9.6/cors",
    "hono/deno": "jsr:@hono/hono@^4.9.6/deno",
    "hono/logger": "jsr:@hono/hono@^4.9.6/logger",
    "vue": "npm:vue@^3.5.21"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022", "deno.ns"],
    "types": ["npm:vite/client"]
  }
}
